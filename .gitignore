# Backups (não versionar)
backups/*
!backups/.gitkeep

# Logs (não versionar)
logs/*
!logs/.gitkeep

# Credenciais e segredos — ignorar host_vars de produção
inventory/host_vars/*.yml
!inventory/host_vars/.gitkeep
!inventory/host_vars/fw-matriz.yml
!inventory/host_vars/fw-filial01.yml
!inventory/host_vars/fw-filial02.yml

# Vault password file
.env
.vault_pass
*.vault_pass

# Arquivos temporários do Ansible
*.retry
__pycache__/
*.pyc
*.pyo

# Arquivos de IDE
.vscode/
.idea/
*.swp
*.swo
